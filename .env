# ═══════════════════════════════════════════════════════════════
# FarmLens RPi Node — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Edit this file to configure your node.
# Lines starting with # are comments and are ignored.
# After editing, restart the service: sudo systemctl restart farmlens
# ═══════════════════════════════════════════════════════════════

# ── Node Identity ───────────────────────────────────────────────
NODE_ID=FL-001
NODE_NAME=FarmLens Node

# ── Network ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Camera ──────────────────────────────────────────────────────
# Use "picamera2" for RPi Camera v1.3 / v2 / HQ (CSI ribbon cable)
# Use "opencv"    for USB webcam
CAMERA_BACKEND=picamera2
CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# ── AI Mode ─────────────────────────────────────────────────────
# "mock"   = random walk Cv, no model needed (prototype mode)
# "tflite" = real inference using models/plant_disease.tflite
AI_MODE=mock
MODEL_FILE=plant_disease.tflite
CONFIDENCE_THRESHOLD=0.25

# ── Sensor Fusion Defaults ───────────────────────────────────────
DEFAULT_W1=0.6
DEFAULT_W2=0.4
DEFAULT_THETA=0.5
DEFAULT_CROP=tomato

# ── Sensor Calibration ───────────────────────────────────────────
MOISTURE_DRY=2800
MOISTURE_WET=1200
MOISTURE_STRESS_THRESHOLD=30.0
WATER_DRY=3000
WATER_WET=500
WATER_STRESS_THRESHOLD=20.0

# ── Timing ───────────────────────────────────────────────────────
CYCLE_INTERVAL_S=30
